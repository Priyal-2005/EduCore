# ━━━ Database ━━━
DATABASE_URL="postgresql://user:password@localhost:5432/educore?schema=public"

# ━━━ Server ━━━
PORT=8000
NODE_ENV=development

# use command in terminal to generate a JWT secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ━━━ CORS ━━━
CORS_ORIGIN=http://localhost:5173